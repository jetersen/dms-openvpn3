{
  "$schema": "https://danklinux.com/schemas/plugin.json",
  "id": "openvpn3",
  "name": "DMS Integration for OpenVPN® 3",
  "description": "Independent DMS integration for OpenVPN® 3 Linux profiles and sessions",
  "version": "0.1.0",
  "author": "Joseph",
  "type": "widget",
  "capabilities": ["vpn", "network", "dankbar-widget"],
  "component": "./OpenVpn3Widget.qml",
  "startupCheck": "./StartupCheck.qml",
  "icon": "vpn_lock",
  "requires_dms": ">=1.5.0",
  "dependencies": ["openvpn3", "python3", "python3-dbus"],
  "permissions": ["process"]
}
